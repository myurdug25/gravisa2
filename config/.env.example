# Gravisa - Ortam değişkenleri
# cp config/.env.example config/.env
# .env dosyası config/ içinde olduğu için web'den erişilemez.
# Detaylı bilgi: DEPLOY.md

# Ortam: production | development
APP_ENV=production

# Web base path: Boş = site kökte. XAMPP localhost/gravisa için: gravisa
# BASE_PATH=

# Hata gösterimi (production'da mutlaka 0)
APP_DEBUG=0

# Uygulama URL kökü (https zorunlu, örn: https://gravisa.com)
APP_URL=

# Saat dilimi (opsiyonel)
APP_TIMEZONE=Europe/Istanbul

# ---------- E-posta (info@gravisamakina.com.tr - hem gelen hem giden) ----------
MAIL_TO=info@gravisamakina.com.tr
MAIL_FROM=info@gravisamakina.com.tr
MAIL_FROM_NAME=Gravisa Makina

# ---------- Site iletişim (numara, mail - admin boşsa bunlar kullanılır) ----------
CONTACT_EMAIL=info@gravisamakina.com.tr
SERVIS_EMAIL=info@gravisamakina.com.tr
WHATSAPP_NUMBER=905551234567
PHONE_DISPLAY=0555 123 45 67

# Hostinger SMTP (smtp.hostinger.com)
MAIL_SMTP_HOST=smtp.hostinger.com
MAIL_SMTP_PORT=465
MAIL_SMTP_USER=info@gravisamakina.com.tr
MAIL_SMTP_PASS=
MAIL_SMTP_SECURE=ssl

# ---------- Admin ----------
ADMIN_USER=admin
ADMIN_PASS=

# Oturum süresi (saniye)
SESSION_LIFETIME=3600

# ---------- Veritabanı (kullanmak için USE_DB=1) ----------
USE_DB=0
DB_HOST=localhost
DB_NAME=gravisa
DB_USER=root
DB_PASS=
